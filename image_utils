"""Image loading and file utilities for DiamondVision Worker 3.0."""

from __future__ import annotations

from collections import Counter
import logging
import os
from pathlib import Path
import shutil
from typing import Iterable

import cv2
import numpy as np

try:
    import rawpy
except ImportError:  # pragma: no cover - handled at runtime
    rawpy = None


LOGGER = logging.getLogger(__name__)

JPEG_EXTENSIONS = {
    ".jpg",
    ".jpeg",
    ".jpe",
}

RAW_EXTENSIONS = {
    ".nef",
    ".cr2",
    ".cr3",
    ".arw",
    ".dng",
    ".orf",
    ".rw2",
    ".raf",
}

SUPPORTED_IMAGE_EXTENSIONS = JPEG_EXTENSIONS | RAW_EXTENSIONS

DEFAULT_MAX_DIMENSION = 2400
DEFAULT_JPEG_QUALITY = 92


class ImageLoadError(RuntimeError):
    """Raised when an image cannot be decoded."""


class RawSupportError(ImageLoadError):
    """Raised when a RAW image is supplied but rawpy is unavailable."""


def rawpy_available() -> bool:
    """Return True when RAW image decoding is available."""
    return rawpy is not None


def rawpy_status() -> dict[str, object]:
    """Return structured RAW support information."""
    return {
        "available": rawpy_available(),
        "library": "rawpy",
        "supported_extensions": sorted(RAW_EXTENSIONS),
    }


def is_supported_image(path: str | os.PathLike[str]) -> bool:
    """Return True when the path has a supported image extension."""
    return Path(path).suffix.lower() in SUPPORTED_IMAGE_EXTENSIONS


def find_images(
    root_directory: str | os.PathLike[str],
) -> list[str]:
    """Recursively find supported images in stable path order."""
    root = Path(root_directory)

    if not root.exists():
        raise FileNotFoundError(
            f"Image directory does not exist: {root}"
        )

    if not root.is_dir():
        raise NotADirectoryError(
            f"Image search root is not a directory: {root}"
        )

    images = [
        path
        for path in root.rglob("*")
        if path.is_file() and is_supported_image(path)
    ]

    images.sort(
        key=lambda path: path.as_posix().lower()
    )

    LOGGER.info(
        "Found %s supported image files in %s.",
        len(images),
        root,
    )

    return [str(path) for path in images]


def extension_counts(
    paths: Iterable[str | os.PathLike[str]],
) -> dict[str, int]:
    """Count file extensions using lowercase suffixes."""
    counter = Counter(
        Path(path).suffix.lower() or "<no_extension>"
        for path in paths
    )

    return dict(sorted(counter.items()))


def load_jpeg(
    path: str | os.PathLike[str],
) -> np.ndarray:
    """Load a JPEG-compatible image as an OpenCV BGR array."""
    source = Path(path)

    if not source.is_file():
        raise FileNotFoundError(
            f"Image file does not exist: {source}"
        )

    try:
        encoded = np.fromfile(
            str(source),
            dtype=np.uint8,
        )
        image = cv2.imdecode(
            encoded,
            cv2.IMREAD_COLOR,
        )
    except Exception as error:
        raise ImageLoadError(
            f"Failed to decode image {source}: "
            f"{type(error).__name__}: {error}"
        ) from error

    if image is None or image.size == 0:
        raise ImageLoadError(
            f"OpenCV could not decode image: {source}"
        )

    return image


def load_raw(
    path: str | os.PathLike[str],
) -> np.ndarray:
    """Load a RAW image and convert it to an OpenCV BGR array."""
    source = Path(path)

    if not source.is_file():
        raise FileNotFoundError(
            f"RAW image does not exist: {source}"
        )

    if rawpy is None:
        raise RawSupportError(
            "RAW support is unavailable because rawpy is not installed."
        )

    try:
        with rawpy.imread(str(source)) as raw:
            rgb = raw.postprocess(
                use_camera_wb=True,
                use_auto_wb=False,
                no_auto_bright=False,
                output_bps=8,
                gamma=(2.222, 4.5),
                highlight_mode=rawpy.HighlightMode.Blend,
            )

        if rgb is None or rgb.size == 0:
            raise ImageLoadError(
                f"RAW decoder returned no image data: {source}"
            )

        return cv2.cvtColor(
            rgb,
            cv2.COLOR_RGB2BGR,
        )

    except ImageLoadError:
        raise

    except Exception as error:
        raise ImageLoadError(
            f"Failed to decode RAW image {source}: "
            f"{type(error).__name__}: {error}"
        ) from error


def load_image(
    path: str | os.PathLike[str],
) -> np.ndarray:
    """Load a supported JPEG or RAW image as an OpenCV BGR array."""
    source = Path(path)
    extension = source.suffix.lower()

    if extension in RAW_EXTENSIONS:
        LOGGER.debug("Loading RAW image: %s", source)
        return load_raw(source)

    if extension in JPEG_EXTENSIONS:
        LOGGER.debug("Loading JPEG image: %s", source)
        return load_jpeg(source)

    raise ImageLoadError(
        f"Unsupported image extension '{extension}' for {source}."
    )


def resize_image(
    image: np.ndarray,
    max_dimension: int = DEFAULT_MAX_DIMENSION,
) -> np.ndarray:
    """Resize an image proportionally so neither side exceeds max_dimension."""
    if image is None or image.size == 0:
        raise ValueError("Cannot resize an empty image.")

    if max_dimension < 1:
        raise ValueError(
            "max_dimension must be greater than zero."
        )

    height, width = image.shape[:2]
    largest_dimension = max(height, width)

    if largest_dimension <= max_dimension:
        return image.copy()

    scale = max_dimension / float(largest_dimension)
    new_width = max(1, round(width * scale))
    new_height = max(1, round(height * scale))

    return cv2.resize(
        image,
        (new_width, new_height),
        interpolation=cv2.INTER_AREA,
    )


def unique_destination(
    destination_directory: str | os.PathLike[str],
    filename: str,
) -> Path:
    """Return a non-conflicting path inside the destination directory."""
    directory = Path(destination_directory)
    directory.mkdir(
        parents=True,
        exist_ok=True,
    )

    source_name = Path(filename).name
    stem = Path(source_name).stem or "image"
    suffix = Path(source_name).suffix

    candidate = directory / source_name
    counter = 2

    while candidate.exists():
        candidate = directory / f"{stem}_{counter}{suffix}"
        counter += 1

    return candidate


def copy_unique(
    source_path: str | os.PathLike[str],
    destination_directory: str | os.PathLike[str],
) -> str:
    """Copy a file without overwriting an existing destination."""
    source = Path(source_path)

    if not source.is_file():
        raise FileNotFoundError(
            f"Copy source does not exist: {source}"
        )

    destination = unique_destination(
        destination_directory,
        source.name,
    )

    shutil.copy2(
        source,
        destination,
    )

    LOGGER.debug(
        "Copied %s to %s.",
        source,
        destination,
    )

    return str(destination)


def save_display_jpeg(
    source_path: str | os.PathLike[str],
    image: np.ndarray,
    destination_directory: str | os.PathLike[str],
    max_dimension: int = DEFAULT_MAX_DIMENSION,
    jpeg_quality: int = DEFAULT_JPEG_QUALITY,
) -> str:
    """Save an image as a uniquely named display JPEG."""
    if image is None or image.size == 0:
        raise ValueError(
            "Cannot save an empty display image."
        )

    if not 1 <= jpeg_quality <= 100:
        raise ValueError(
            "jpeg_quality must be between 1 and 100."
        )

    source = Path(source_path)
    output_name = f"{source.stem or 'image'}.jpg"

    destination = unique_destination(
        destination_directory,
        output_name,
    )

    resized = resize_image(
        image,
        max_dimension=max_dimension,
    )

    encode_success, encoded = cv2.imencode(
        ".jpg",
        resized,
        [
            int(cv2.IMWRITE_JPEG_QUALITY),
            int(jpeg_quality),
            int(cv2.IMWRITE_JPEG_OPTIMIZE),
            1,
        ],
    )

    if not encode_success:
        raise ImageLoadError(
            f"OpenCV failed to encode display JPEG: {destination}"
        )

    destination.parent.mkdir(
        parents=True,
        exist_ok=True,
    )

    try:
        encoded.tofile(
            str(destination)
        )
    except Exception as error:
        raise OSError(
            f"Failed to save display JPEG {destination}: "
            f"{type(error).__name__}: {error}"
        ) from error

    if not destination.is_file():
        raise OSError(
            f"Display JPEG was not created: {destination}"
        )

    LOGGER.debug(
        "Saved display JPEG: %s",
        destination,
    )

    return str(destination)
